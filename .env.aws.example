# AWS mode frontend configuration example
# Copy values into .env only when AWS resources exist.
# Do not commit .env.
# Do not put secret access keys, session tokens, root credentials, service-role keys, or passwords here.

# demo = current browser/localStorage prototype
# aws = future Cognito/API-backed mode
VITE_APP_BACKEND_MODE=demo

# Use / for AWS Amplify Hosting.
# GitHub Pages deployment uses /field-copilot-pro/ in its workflow.
VITE_BASE_PATH=/

# Safe public AWS frontend config values after Cognito/API exist.
VITE_AWS_REGION=us-east-1
VITE_AWS_COGNITO_USER_POOL_ID=
VITE_AWS_COGNITO_USER_POOL_CLIENT_ID=
VITE_AWS_APPSYNC_GRAPHQL_URL=
